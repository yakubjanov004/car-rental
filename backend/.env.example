SECRET_KEY=django-insecure-car-rental-secret-key-production-ready
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://yourdomain.com

# Database (PostgreSQL)
DB_NAME=ridelux_db
DB_USER=ridelux_user
DB_PASSWORD=securepassword
DB_HOST=db
DB_PORT=5432

# Production Static/Media
MEDIA_URL=/media/
MEDIA_ROOT=media/
STATIC_ROOT=static/

# Frontend (API URL)
VITE_API_URL=https://api.yourdomain.com/api

# ============================================================
#  PAYMENT GATEWAYS
# ============================================================

# --- Payme (payme.uz) ---
# Register at https://merchant.payme.uz to get credentials
PAYME_ID=your-payme-merchant-id
PAYME_KEY=your-payme-key
PAYME_TEST_MODE=True
PAYME_RETURN_URL=http://localhost:5173/profile

# --- Click (click.uz) ---
# Register at https://merchant.click.uz to get credentials
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_MERCHANT_USER_ID=your-click-merchant-user-id
CLICK_SECRET_KEY=your-click-secret-key
CLICK_RETURN_URL=http://localhost:5173/profile
